# Application
APP_ENV=development
APP_NAME=multi-tenant-saas
LOG_LEVEL=debug

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=multitenant
DATABASE_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# NATS
NATS_URL=nats://localhost:4222

# JWT
JWT_SECRET=your-super-secret-key-change-in-production-use-rsa-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=multitenant-saas

# RSA Keys (for RS256 in production)
# Generate with: openssl genrsa -out app.rsa 2048
# openssl rsa -in app.rsa -pubout -out app.rsa.pub
JWT_RSA_PRIVATE_KEY_PATH=./keys/app.rsa
JWT_RSA_PUBLIC_KEY_PATH=./keys/app.rsa.pub

# API Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# Auth Service
AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=3001

# Billing Service
BILLING_SERVICE_HOST=localhost
BILLING_SERVICE_PORT=3002

# Analytics Service
ANALYTICS_SERVICE_HOST=localhost
ANALYTICS_SERVICE_PORT=3003

# Tenant Service
TENANT_SERVICE_HOST=localhost
TENANT_SERVICE_PORT=3004

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Stripe
STRIPE_API_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
